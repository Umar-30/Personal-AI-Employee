{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@bronze/*": ["./bronze/src/*"]
    }
  },
  "include": ["bronze/src/**/*", "silver/src/**/*", "gold/src/**/*", "platinum/src/**/*"],
  "exclude": ["node_modules", "dist", "bronze/tests", "silver/tests", "gold/tests", "platinum/tests"]
}
